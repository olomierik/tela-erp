# Tela ERP Environment Configuration
# Copy this file to .env and fill in the required values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Database Configuration (for offline/local mode)
DB_HOST=localhost
DB_PORT=5432
DB_USER=tela_user
DB_PASSWORD=tela_password
DB_NAME=tela_erp

# Application Settings
NODE_ENV=production
VITE_APP_NAME=Tela ERP
VITE_APP_VERSION=1.0.0

# Email Configuration (for transactional emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@tela-erp.com

# API Configuration
VITE_API_URL=http://localhost:5000
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_AI_CFO=true
VITE_ENABLE_MOBILE_MONEY=true
VITE_ENABLE_OFFLINE_MODE=true

# Security
VITE_JWT_SECRET=your-jwt-secret-key
VITE_ENCRYPTION_KEY=your-encryption-key

# Analytics (optional)
VITE_ANALYTICS_ID=your-analytics-id

# Third-party Integrations
VITE_STRIPE_PUBLIC_KEY=pk_test_your_key
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/tela-erp.log

# Performance
VITE_CACHE_ENABLED=true
VITE_CACHE_TTL=3600

# Development
VITE_DEBUG_MODE=false
VITE_HOT_RELOAD=true
